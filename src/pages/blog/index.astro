---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Section from "../../components/Section.astro";
import BlogNavbar from "../../components/BlogNavbar.astro";
export const prerender = false;

let allPosts = await getCollection("blog");
const seriesPosts = await getCollection("series");

allPosts = allPosts.filter((post) => !post.data.draft);

const requestedTag = Astro.url.searchParams.get("tag");
const tags = [
  ...new Set(allPosts.flatMap((post) => post.data.tags ?? [])),
].sort();
const selectedTag =
  requestedTag && tags.includes(requestedTag) ? requestedTag : "";

const filteredPosts = selectedTag
  ? allPosts.filter((post) => post.data.tags.includes(selectedTag))
  : allPosts;
---

<Layout>
  <Section id="blog-page-header-section" class="container">
    <BlogNavbar tags={tags} selectedTag={selectedTag} />
  </Section>
  <Section class="contrast section--height-1/4" id="blog-page-section">
    <div>
      <header>
        <h2>Posts</h2>
      </header>
      <ul class="grid" style="padding-left: 0;">
        {
          filteredPosts.map((post) => (
            <li class="post-card">
              <div>
                <header class="group">
                  <h2 class="h3">
                    <a href={`/blog/${post.id}`}>{post.data.title}</a>
                  </h2>
                  <div class="tags-container">
                    {post.data.tags.map((tag) => (
                      <i class="tag">{tag}</i>
                    ))}
                  </div>
                </header>
                <p>{post.data.description}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <header class="group">
        <h2>
          Allez, Allez, Allez! <small
            style="font-size: 50%; color: var(--orange)">series</small>
        </h2>
        <p>Learning the Go programming language.</p>
      </header>
      <ul class="grid" style="padding-left: 0;">
        {
          seriesPosts.filter((post) => !post.data.draft).length > 0
            ? seriesPosts.map((post) => (
                <li class="post-card">
                  <div>
                    <header class="group">
                      <h2 class="h3">
                        <a href={`/blog/${post.id}`}>{post.data.title}</a>
                      </h2>
                      <div class="tags-container">
                        {post.data.tags.map((tag) => (
                          <i class="tag">{tag}</i>
                        ))}
                      </div>
                    </header>
                    <p>{post.data.description}</p>
                  </div>
                </li>
              ))
            : "Coming Soon!"
        }
      </ul>
    </div>
  </Section>
</Layout>

<style>
  .post-card {
    list-style: none;
    background-color: var(--app-surface-color--opaque);
    padding: 1rem;
    border: var(--app-border-color) var(--app-border-width) solid;

    box-shadow: var(--app-box-shadow);
    transition: box-shadow var(--app-transition);

    header {
      display: flex;
      flex-direction: column;
      align-items: start;
      .tags-container {
        display: flex;
        gap: var(--app-spacing);
        flex-direction: row;
      }
      .tag {
        font-weight: 600;
        color: var(--orange);
      }
    }
  }

  .post-card:hover {
    box-shadow: var(--app-box-shadow--hover);
  }
</style>
